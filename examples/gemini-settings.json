{
  "mcpServers": {
    "zigar": {
      "command": "/absolute/path/to/zigar",
      "args": [
        "--transport",
        "stdio",
        "--workspace",
        "/absolute/path/to/zig/project",
        "--zig-path",
        "/absolute/path/to/zig",
        "--zls-path",
        "/absolute/path/to/zls"
      ],
      "cwd": "/absolute/path/to/zig/project",
      "timeout": 600000,
      "trust": false
    }
  }
}
