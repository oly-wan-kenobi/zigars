{
    "name": "@zigars/mcp",
    "version": "0.2.0",
    "description": "npm shim for the zigar local stdio MCP server",
    "license": "MIT",
    "mcpName": "io.github.oly-wan-kenobi/zigar",
    "main": "dist/src/cli.js",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/oly-wan-kenobi/zigar.git",
        "directory": "packages/zigar-mcp-npm"
    },
    "homepage": "https://github.com/oly-wan-kenobi/zigar#readme",
    "bugs": {
        "url": "https://github.com/oly-wan-kenobi/zigar/issues"
    },
    "keywords": [
        "zig",
        "mcp",
        "model-context-protocol",
        "zigar",
        "codex",
        "claude",
        "cursor",
        "vscode"
    ],
    "bin": {
        "zigar-mcp": "bin/zigar-mcp.js"
    },
    "files": [
        "bin",
        "dist/package.json",
        "dist/src",
        "src",
        "tsconfig.json",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist",
        "prepack": "npm run build",
        "test": "bun run test:bun",
        "test:bun": "bun run build && bun test test/*.test.ts",
        "test:node": "npm run build && node --test dist/test/*.test.js"
    },
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "typescript": "^5.9.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
