{
  "name": "zigars",
  "purpose": "Deterministic Zig development MCP server. No AI generation. Source writes require apply=true.",
  "schema_version": 1,
  "safety": {
    "stdout": "MCP JSON-RPC only",
    "path_boundary": "realpath workspace boundary",
    "source_write_gate": "apply=true",
    "symlink_escapes": "rejected",
    "argument_validation": "typed metadata before handler execution",
    "free_form_args": "split into argv without shell execution"
  },
  "common_intents": [
    {"intent": "format a Zig file", "prefer": "zig_format", "keywords": ["fmt", "formatter", "formatting", "zig fmt"]},
    {"intent": "orient an agent in a Zig repo", "prefer": "zigars_context_pack", "keywords": ["context pack", "repo summary", "codex", "claude", "gemini", "hermes", "agent"]},
    {"intent": "choose the next Zig workflow step", "prefer": "zigars_next_action", "keywords": ["next action", "workflow", "what next", "plan"]},
    {"intent": "validate an agent patch", "prefer": "zigars_validate_patch", "keywords": ["validate patch", "done check", "readiness", "final gate"]},
    {"intent": "plan and run validation safely", "prefer": "zigars_validation_plan, zigars_validation_run", "keywords": ["validation plan", "validation run", "risk-aware validation", "skipped phases"]},
    {"intent": "preview and apply a transactional edit", "prefer": "zigars_patch_session_create, zigars_patch_session_preview, zigars_patch_session_apply, zigars_patch_session_revert", "keywords": ["patch session", "transactional edit", "preimage", "rollback", "multi-file edit"]},
    {"intent": "route generated or vendor edits", "prefer": "zigars_edit_policy_check, zig_generated_file_trace, zigars_generated_route", "keywords": ["generated file", "vendor", "edit policy", "regenerate", "generated route"]},
    {"intent": "preview a Zig refactor", "prefer": "zig_move_decl, zig_extract_decl, zig_update_imports, zig_organize_imports", "keywords": ["refactor", "move declaration", "extract declaration", "update imports", "organize imports"]},
    {"intent": "fuse compiler and test failures", "prefer": "zigars_failure_fusion", "keywords": ["failure fusion", "primary failure", "compiler test triage"]},
    {"intent": "parse build and test output events", "prefer": "zig_build_events, zig_test_events, zig_test_timing", "keywords": ["build events", "test events", "timing", "captured output"]},
    {"intent": "analyze impact of touched files", "prefer": "zigars_impact", "keywords": ["impact", "affected tests", "importers", "symbols"]},
    {"intent": "analyze parser-backed semantic impact", "prefer": "zig_impact_semantic, zig_test_select_semantic", "keywords": ["semantic impact", "semantic test select", "parser backed tests", "affected importers"]},
    {"intent": "inspect architecture-neutral project structure", "prefer": "zig_import_cycles, zig_module_surface, zig_symbol_dossier, zig_insertion_sites", "keywords": ["import cycles", "module surface", "symbol dossier", "insertion sites", "architecture neutral"]},
    {"intent": "catalog tests and safety review sites", "prefer": "zig_test_name_resolve, zig_test_fixture_inventory, zig_safety_site_catalog, zig_test_for_symbol", "keywords": ["test filters", "fixture inventory", "safety sites", "panic", "unreachable", "test for symbol"]},
    {"intent": "analyze Zig migration, comptime, memory, and unsafe-operation pain points", "prefer": "zig_io_migration_scan, zig_comptime_diagnose, zig_leak_triage, zig_memory_layout, zig_unsafe_operations_audit, zig_abi_layout_diff", "keywords": ["io migration", "std.io", "std.Io", "comptime diagnose", "gpa leak", "memory layout", "compiler backed layout", "target layout", "unsafe operations", "abi layout"]},
    {"intent": "risk-rank a planned source change", "prefer": "zig_change_risk_audit, zig_changed_files_plan, zig_test_select", "keywords": ["change risk", "risk audit", "public api delta", "importer count", "validation planning"]},
    {"intent": "summarize validation history", "prefer": "zigars_validation_history, zig_test_flake_history, zig_failure_history", "keywords": ["validation history", "flake history", "failure history", "recurring failures"]},
    {"intent": "prepare an agent handoff", "prefer": "zigars_session_snapshot, zigars_handoff_pack", "keywords": ["handoff", "session snapshot", "resume work", "agent state"]},
    {"intent": "read project memory", "prefer": "zigars_project_memory, zigars_project_notes, zigars_decision_record", "keywords": ["project memory", "decision record", "project notes", "apply gate"]},
    {"intent": "match goals to zigars tools", "prefer": "zigars_capability_match, zigars_tool_sequence_plan", "keywords": ["capability match", "tool sequence", "tool routing", "workflow plan"]},
    {"intent": "check formatting without writing", "prefer": "zig_format_check", "keywords": ["fmt check", "zig fmt --check", "style check"]},
    {"intent": "understand compiler errors", "prefer": "zig_explain_errors", "keywords": ["compiler errors", "fix build", "diagnostics"]},
    {"intent": "group compiler errors by file", "prefer": "zig_compile_error_index", "keywords": ["compile error index", "diagnostics", "file errors"]},
    {"intent": "inspect planning support for a tool", "prefer": "zig_tool_plan", "keywords": ["plan", "planning", "argv", "zls request", "tool discovery"]},
    {"intent": "answer setup, profile, and backend ambiguity", "prefer": "zigars_setup_guidance, zigars_profile_guidance, zigars_backend_guidance", "keywords": ["setup guidance", "profile questions", "backend questions", "elicitation compatibility"]},
    {"intent": "resolve Zig toolchain mismatch", "prefer": "zig_toolchain_resolve", "keywords": ["toolchain", "zig version", "zls version", "mise", "asdf", "zvm", "zigup"]},
    {"intent": "plan checks for dirty files", "prefer": "zig_changed_files_plan", "keywords": ["changed files", "git status", "minimal checks"]},
    {"intent": "select focused tests", "prefer": "zig_test_select", "keywords": ["test select", "impacted tests", "focused tests"]},
    {"intent": "detect public API changes", "prefer": "zig_public_api_diff", "keywords": ["public api diff", "breaking change", "api"]},
    {"intent": "inspect build dependencies", "prefer": "zig_dependency_inspect", "keywords": ["build.zig.zon", "dependency", "hash", "zig-pkg"]},
    {"intent": "ingest CI failure evidence", "prefer": "zig_ci_ingest, zig_ci_repro_plan, zig_ci_failure_map", "keywords": ["ci ingest", "ci repro", "failure map", "junit", "sarif", "annotations"]},
    {"intent": "plan release readiness", "prefer": "zig_release_plan, zig_semver_suggest, zig_release_notes_draft, zig_release_evidence_pack", "keywords": ["release plan", "semver", "release notes", "evidence pack"]},
    {"intent": "manage public API lifecycle evidence", "prefer": "zig_api_baseline_init, zig_api_check, zig_api_diff_baseline, zig_api_docs_diff", "keywords": ["api baseline", "api check", "api docs diff", "breaking change"]},
    {"intent": "verify docs examples and snippets", "prefer": "zig_docs_query, zig_project_docs_query, zig_doc_example_check, zig_snippet_check, zig_readme_command_check", "keywords": ["docs query", "autodoc", "doc examples", "snippet check", "readme commands"]},
    {"intent": "audit dependency and security evidence", "prefer": "zig_dependency_update_plan, zig_dependency_fetch_check, zig_dependency_lock_audit, zig_sbom, zig_osv_scan, zig_zat_scan, zig_dependency_security_report, zig_dependency_provenance", "keywords": ["dependency update", "sbom", "osv", "zat", "security report", "license", "provenance"]},
    {"intent": "manage build.zig.zon dependencies", "prefer": "zig_zon_dep_sync, zig_deps_add, zig_deps_remove, zig_deps_upgrade, zig_dependency_migrate", "keywords": ["build.zig.zon mutation", "zig fetch hash", "dependency add", "dependency remove", "dependency upgrade", "dependency migration", "apply=true"]},
    {"intent": "browse Zig package metadata", "prefer": "zig_pkg_search, zig_pkg_info, zig_pkg_versions, zig_pkg_readme", "keywords": ["package search", "zigistry", "direct url", "dependency registry", "package versions", "readme"]},
    {"intent": "find symbol information", "prefer": "zig_hover, zig_definition, zig_references, zig_document_symbols", "keywords": ["zls", "lsp", "symbol", "definition", "references"]},
    {"intent": "search Zig docs", "prefer": "zig_builtin_doc, zig_std_search, zig_std_item, zig_lang_ref_search", "keywords": ["docs", "stdlib", "builtin", "langref", "language reference", "source provenance"]},
    {"intent": "query parser-backed Zig symbols", "prefer": "zig_semantic_query, zig_semantic_decl, zig_semantic_refs, zig_semantic_callers", "keywords": ["semantic index", "semantic query", "declaration", "references", "callers", "zlint ast"]},
    {"intent": "lint Zig code", "prefer": "zig_zlint, zig_zlint_fix, zig_lint, zig_lint_compare", "keywords": ["zlint", "zwanzig", "lint", "linter", "lint compare", "lint gate", "sarif", "fix lint"]},
    {"intent": "plan profiling capture", "prefer": "zig_profile_plan", "keywords": ["profile plan", "external capture", "perf", "xctrace", "sample", "dtrace", "vtune"]},
    {"intent": "make a flamegraph", "prefer": "zig_flamegraph", "keywords": ["zflame", "profile", "perf", "flamegraph"]},
    {"intent": "normalize coverage evidence", "prefer": "zig_coverage_map, zig_coverage_diff, zig_coverage_budget_check", "keywords": ["coverage", "lcov", "coverage budget", "coverage baseline"]},
    {"intent": "run and compare benchmarks", "prefer": "zig_bench_discover, zig_bench_run, zig_bench_compare, zig_bench_regression_gate, zig_perf_budget_check", "keywords": ["benchmark", "bench", "baseline", "performance budget", "regression", "regression gate", "session"]},
    {"intent": "record profiler evidence", "prefer": "zig_samply_record, zig_tracy_capture, zig_perf_evidence_pack", "keywords": ["samply", "tracy", "profile artifact", "performance evidence"]},
    {"intent": "debug runtime crashes", "prefer": "zig_debug_plan, zig_lldb_backtrace, zig_core_inspect, zig_sanitizer_fusion, zig_panic_trace_analyze, zig_crash_repro_plan", "keywords": ["debug", "lldb", "core dump", "sanitizer", "panic", "crash repro"]},
    {"intent": "run memory and fuzz diagnostics", "prefer": "zig_heaptrack_run, zig_valgrind_memcheck, zig_callgrind_report, zig_fuzz_plan, zig_afl_run, zig_libfuzzer_run", "keywords": ["heaptrack", "valgrind", "callgrind", "fuzz", "afl", "libfuzzer", "corpus"]},
    {"intent": "inspect binary and cross-target runtime artifacts", "prefer": "zig_binary_size, zig_binary_size_diff, zig_objdump_summary, zig_dwarfdump_check, zig_symbolize, zig_qemu_test, zig_cross_smoke", "keywords": ["binary size", "objdump", "dwarf", "symbolize", "qemu", "cross target"]},
    {"intent": "plan embedded and flash workflows", "prefer": "zig_embedded_detect, zig_microzig_plan, zig_board_profile, zig_flash_plan", "keywords": ["embedded", "microzig", "board", "firmware", "flash", "probe-rs", "openocd"]},
    {"intent": "inspect generated evidence artifacts", "prefer": "zigars_artifact_index, zigars_artifact_read", "keywords": ["artifact", "registry", "provenance", "sha256", "evidence"]},
    {"intent": "inspect persisted workflow sessions", "prefer": "zigars_session_view", "keywords": ["session", "jsonl", "workflow session", "dependency migration", "bench regression gate", "inspect only"]},
    {"intent": "inspect zigars runtime health", "prefer": "zigars_metrics_v2, zigars_tool_latency", "keywords": ["metrics", "observability", "latency", "backend health", "zls timeline"]},
    {"intent": "explain zigars safety posture", "prefer": "zigars_trust_report, zigars_risk_audit", "keywords": ["trust", "safety", "risk", "command provenance", "clean tree"]},
    {"intent": "choose compact or deep output", "prefer": "zigars_result_shape, zigars_output_budget_plan", "keywords": ["result shape", "compact", "deep", "omitted sections", "token budget"]},
    {"intent": "check docs and release drift", "prefer": "zigars_docs_drift_check, zigars_tool_index_check", "keywords": ["docs drift", "release claims", "tool index", "release-check"]},
    {"intent": "package zigars adoption evidence", "prefer": "zigars_adoption_pack, zigars_client_config_generate, zigars_smoke_plan, zigars_conformance_report", "keywords": ["adoption", "client config", "mcp config", "smoke plan", "conformance report", "public claims"]},
    {"intent": "install optional backends", "prefer": "zigars_backend_catalog", "keywords": ["backend setup", "zls", "zlint", "zwanzig", "zflame", "diff-folded", "samply", "tracy"]},
    {"intent": "diagnose zigars setup", "prefer": "zigars_doctor", "keywords": ["doctor", "health", "backend", "permission denied", "workspace"]}
  ],
  "tool_argument_scope": "Compact high-signal argument and planning hints are generated from the typed manifest under src/manifest/ at build and runtime.",
  "tools_list_schema_note": "tools/list publishes each registered inputSchema with properties, required fields, defaults, enums, and zigars path hints; pilot tools also publish shared outputSchema envelopes. zigars_schema and zigars://tools/schema remain available as compact catalog views with grouping, risk, planning, and discovery keywords."
}
